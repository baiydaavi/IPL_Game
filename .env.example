# Copy this file to `.env.local` and fill in the values.
# `.env.local` is git-ignored and never committed.

# ---- Supabase ---------------------------------------------------------------
# From your Supabase project settings -> API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ---- CricketData / CricAPI --------------------------------------------------
# https://cricketdata.org. The paid tier ($5.99/mo) gives 2000 hits/day at
# 1 hit per endpoint and is what the app assumes. The free tier (100 hits/day
# with a 10x multiplier on squad/scorecard endpoints) is effectively unusable.
CRICKET_API_KEY=

# ---- Admin allowlist --------------------------------------------------------
# Comma-separated emails allowed to access /admin and manual-override endpoints.
ADMIN_EMAILS=

# ---- Cron secret ------------------------------------------------------------
# Vercel Cron uses this as a bearer token when hitting /api/cron/* routes.
CRON_SECRET=

# ---- Demo mode (local UI / rule testing only) -------------------------------
# When set to 1:
#   - Bypasses Supabase auth and seeds two fake users (Player A, Player B).
#   - Seeds a fake fixture (CSK vs MI) + fake squads so the app runs without
#     any CricAPI calls. CRICKET_API_KEY can be left blank.
#   - Enables a floating panel to switch identity, flip match state
#     (not-started / live / finished), and swap between preset scorecards
#     (normal / rain-draw / bowler-penalty / impact-sub / etc).
# LEAVE UNSET in production.
DEMO_MODE=
